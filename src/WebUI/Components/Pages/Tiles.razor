@page "/tiles"
@using LibreRally.Maps.WebUI
@inject TileApiClient Api
@inject IJSRuntime JS
@implements IAsyncDisposable
@rendermode InteractiveServer

<PageTitle>Tiles — LibreRally Maps</PageTitle>

<div class="container-fluid">
    <h3 class="mb-4">Tile Catalog</h3>

    <div class="row g-3 mb-3">
        <div class="col-sm-6 col-xl-3">
            <div class="card h-100">
                <div class="card-body">
                    <div class="text-muted small text-uppercase">Tiles</div>
                    <div class="fs-4 fw-semibold">@tiles.Count</div>
                    <div class="small text-muted">Generated tile records currently in the catalog.</div>
                </div>
            </div>
        </div>
        <div class="col-sm-6 col-xl-3">
            <div class="card h-100">
                <div class="card-body">
                    <div class="text-muted small text-uppercase">Active imports</div>
                    <div class="fs-4 fw-semibold">@imports.Count(importRecord => importRecord.Status == "active")</div>
                    <div class="small text-muted">Distinct LAS imports feeding the active point bucket.</div>
                </div>
            </div>
        </div>
        <div class="col-sm-6 col-xl-3">
            <div class="card h-100">
                <div class="card-body">
                    <div class="text-muted small text-uppercase">LAS jobs</div>
                    <div class="fs-4 fw-semibold">@lasJobs.Count</div>
                    <div class="small text-muted">@lasJobs.Count(job => IsActiveStatus(job.Status)) in progress.</div>
                </div>
            </div>
        </div>
        <div class="col-sm-6 col-xl-3">
            <div class="card h-100">
                <div class="card-body">
                    <div class="text-muted small text-uppercase">Processing jobs</div>
                    <div class="fs-4 fw-semibold">@pipelineJobs.Count</div>
                    <div class="small text-muted">@pipelineJobs.Count(job => IsActiveStatus(job.Status)) rebuilding the active bucket.</div>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-md-7">
            <div style="height: 500px; border-radius: 8px; overflow: hidden; border: 1px solid #dee2e6;">
                <div id="tiles-map" style="height:100%;width:100%"></div>
            </div>
        </div>
        <div class="col-md-5">
            <div class="card mb-3">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <span>Tiles (@tiles.Count)</span>
                    <div>
                        <button class="btn btn-sm btn-outline-primary me-1" @onclick="Refresh">Refresh</button>
                        <button class="btn btn-sm btn-success" @onclick="ProcessNext" disabled="@processing">
                            @(processing ? "Starting..." : "Reprocess Active Imports")
                        </button>
                    </div>
                </div>
                <div class="card-body p-0" style="max-height: 300px; overflow-y: auto;">
                    <table class="table table-sm table-hover mb-0">
                        <thead><tr><th>Tile</th><th>Z</th><th>Features</th><th>Age</th></tr></thead>
                        <tbody>
                            @foreach (var t in tiles)
                            {
                                <tr class="@(selectedTile?.Id == t.Id ? "table-active" : "")" 
                                    @onclick="() => SelectTile(t)" style="cursor:pointer">
                                    <td>(@t.TileX, @t.TileY)</td><td>@t.ZoomLevel</td>
                                    <td>@string.Join(", ", t.FeatureTypes ?? [])</td>
                                    <td>@((DateTime.UtcNow - t.CreatedAt).TotalHours.ToString("F0"))h ago</td>
                                </tr>
                            }
                            @if (!tiles.Any())
                            {
                                <tr><td colspan="4" class="text-muted">
                                    No tiles yet. Upload LAS from <a href="import">Import</a>; processing now starts automatically.
                                </td></tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            @if (!string.IsNullOrEmpty(statusMsg))
            {
                <div class="alert alert-info">@statusMsg</div>
            }

            @if (lasJobs.Any())
            {
                <div class="card">
                    <div class="card-header">Recent LAS jobs</div>
                    <div class="card-body p-0" style="max-height: 240px; overflow-y: auto;">
                        <table class="table table-sm mb-0">
                            <thead><tr><th>File</th><th>Status</th><th>Progress</th><th>Details</th></tr></thead>
                            <tbody>
                                @foreach (var job in lasJobs.Take(8))
                                {
                                    <tr>
                                        <td><small>@job.FileName</small></td>
                                        <td><small><span class="badge @GetStatusBadgeClass(job.Status)">@FormatStatus(job.Status)</span></small></td>
                                        <td style="min-width: 180px;">
                                            <div class="progress" style="height: 0.55rem;">
                                                <div class="progress-bar @GetProgressBarClass(job.Status) @(IsActiveStatus(job.Status) ? "progress-bar-striped progress-bar-animated" : null)"
                                                     role="progressbar"
                                                     style="width:@($"{GetProgressPercent(job.CurrentStage, job.TotalStages, job.Status)}%")"></div>
                                            </div>
                                            <small class="text-muted">@GetProgressSummary(job.CurrentStage, job.TotalStages)</small>
                                        </td>
                                        <td>
                                            <small>@(job.Message ?? job.Error ?? "—")</small>
                                            @if (job.TotalBatches > 1)
                                            {
                                                <div><small class="text-muted">@GetBatchSummary(job.CurrentBatchIndex, job.TotalBatches)</small></div>
                                            }
                                            @if (job.TotalSteps > 0)
                                            {
                                                <div><small class="text-muted">@job.CompletedSteps:N0 / @job.TotalSteps:N0 points loaded for processing</small></div>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            }

            @if (pipelineJobs.Any())
            {
                <div class="card mt-3">
                    <div class="card-header">Recent processing jobs</div>
                    <div class="card-body p-0" style="max-height: 240px; overflow-y: auto;">
                        <table class="table table-sm mb-0">
                            <thead><tr><th>Job</th><th>Status</th><th>Progress</th><th>Details</th></tr></thead>
                            <tbody>
                                @foreach (var job in pipelineJobs.Take(8))
                                {
                                    <tr>
                                        <td>
                                            <small>@job.FileName</small>
                                            <div><small class="text-muted">@((job.SourceImportIds?.Length ?? 0).ToString()) import(s)</small></div>
                                        </td>
                                        <td><small><span class="badge @GetStatusBadgeClass(job.Status)">@FormatStatus(job.Status)</span></small></td>
                                        <td style="min-width: 180px;">
                                            <div class="progress" style="height: 0.55rem;">
                                                <div class="progress-bar @GetProgressBarClass(job.Status) @(IsActiveStatus(job.Status) ? "progress-bar-striped progress-bar-animated" : null)"
                                                     role="progressbar"
                                                     style="width:@($"{GetProgressPercent(job.CurrentStage, job.TotalStages, job.Status)}%")"></div>
                                            </div>
                                            <small class="text-muted">@GetProgressSummary(job.CurrentStage, job.TotalStages)</small>
                                        </td>
                                        <td>
                                            <small>@(job.Message ?? job.Error ?? "—")</small>
                                            @if (job.TotalBatches > 1)
                                            {
                                                <div><small class="text-muted">@GetBatchSummary(job.CurrentBatchIndex, job.TotalBatches)</small></div>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            }
        </div>
    </div>

    @if (selectedTile is not null)
    {
        <div class="card mt-3">
            <div class="card-header">Tile (@selectedTile.TileX, @selectedTile.TileY) — @selectedTile.Id</div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-6">
                        <h6>Metadata</h6>
                        <dl class="row mb-0 small">
                            <dt class="col-sm-4">Created</dt><dd class="col-sm-8">@selectedTile.CreatedAt.ToLocalTime().ToString("f")</dd>
                            <dt class="col-sm-4">Features</dt><dd class="col-sm-8">@string.Join(", ", selectedTile.FeatureTypes ?? [])</dd>
                            <dt class="col-sm-4">Imports</dt><dd class="col-sm-8">@((selectedTile.SourceImportIds?.Length ?? 0).ToString()) active source import(s)</dd>
                            <dt class="col-sm-4">Tileset</dt><dd class="col-sm-8"><code>@selectedTile.TilesetPath</code></dd>
                        </dl>
                    </div>
                    <div class="col-md-6">
                        <h6>Pipeline Status</h6>
                        <div class="small">
                            @{
                                var hasMesh = selectedTile.MeshCount > 0;
                                var relatedJob = FindRelatedImportJob(selectedTile);
                                var relatedPipeline = FindRelatedPipelineJob(selectedTile);
                            }
                            <span class="text-success">✓ Ingested</span><br>
                            @if (relatedPipeline is not null && IsActiveStatus(relatedPipeline.Status))
                            {
                                <span class="text-primary">⏳ @FormatStatus(relatedPipeline.Status)</span><br>
                                <div class="progress mt-2 mb-1" style="height: 0.7rem; max-width: 360px;">
                                    <div class="progress-bar @GetProgressBarClass(relatedPipeline.Status) progress-bar-striped progress-bar-animated"
                                         role="progressbar"
                                         style="width:@($"{GetProgressPercent(relatedPipeline.CurrentStage, relatedPipeline.TotalStages, relatedPipeline.Status)}%")"></div>
                                </div>
                                <span class="text-muted small">@GetProgressSummary(relatedPipeline.CurrentStage, relatedPipeline.TotalStages)</span><br>
                                <span class="text-muted small">@relatedPipeline.Message</span>
                                @if (relatedPipeline.TotalBatches > 1)
                                {
                                    <br />
                                    <span class="text-muted small">@GetBatchSummary(relatedPipeline.CurrentBatchIndex, relatedPipeline.TotalBatches)</span>
                                }
                            }
                            else if (relatedJob is not null && IsActiveStatus(relatedJob.Status))
                            {
                                <span class="text-primary">⏳ @FormatStatus(relatedJob.Status)</span><br>
                                <div class="progress mt-2 mb-1" style="height: 0.7rem; max-width: 360px;">
                                    <div class="progress-bar @GetProgressBarClass(relatedJob.Status) progress-bar-striped progress-bar-animated"
                                         role="progressbar"
                                         style="width:@($"{GetProgressPercent(relatedJob.CurrentStage, relatedJob.TotalStages, relatedJob.Status)}%")"></div>
                                </div>
                                <span class="text-muted small">@GetProgressSummary(relatedJob.CurrentStage, relatedJob.TotalStages)</span><br>
                                <span class="text-muted small">@relatedJob.Message</span>
                            }
                            else if (hasMesh)
                            {
                                <span class="text-success">✓ Classify + Reconstruct + GLB complete</span><br>
                                <span class="text-muted">Mesh: @selectedTile.MeshCount, Path: @selectedTile.TilesetPath</span>
                            }
                            else if (relatedJob is not null)
                            {
                                <span class="text-primary">⏳ @FormatStatus(relatedJob.Status)</span><br>
                                <span class="text-muted small">@relatedJob.Message</span>
                            }
                            else
                            {
                                <span class="text-warning">∘ No completed mesh yet</span><br>
                                <span class="text-muted small">Automatic processing should start from Import. Use reprocess if you need to retry the active import bucket.</span>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private List<TileEntry> tiles = [];
    private List<ImportJobDisplay> lasJobs = [];
    private List<PipelineJob> pipelineJobs = [];
    private List<ImportRecordItem> imports = [];
    private TileEntry? selectedTile;
    private bool mapInit, processing;
    private string statusMsg = "";
    private readonly CancellationTokenSource refreshCts = new();
    private readonly SemaphoreSlim refreshLock = new(1, 1);
    private Task? refreshLoop;
    private bool disposed;

    protected override async Task OnInitializedAsync()
    {
        await Refresh();
        refreshLoop = PollAsync(refreshCts.Token);
    }

    public async ValueTask DisposeAsync()
    {
        disposed = true;
        refreshCts.Cancel();

        if (refreshLoop is not null)
        {
            try
            {
                await refreshLoop;
            }
            catch (OperationCanceledException)
            {
            }
        }

        refreshCts.Dispose();
        refreshLock.Dispose();
        await DisposeMapAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !mapInit)
        {
            await DrawMarkers(initializing: true);
        }
    }

    private async Task DrawMarkers(bool initializing = false)
    {
        if ((!mapInit && !initializing) || disposed)
            return;

        var markers = tiles
            .Select(t =>
            {
                if (!TryGetTileCenter(t, out var lat, out var lon))
                    return null;

                return new
                {
                    lon,
                    lat,
                    label = $"Tile ({t.TileX},{t.TileY}) z{t.ZoomLevel}: {string.Join(", ", t.FeatureTypes ?? [])}"
                };
            })
            .Where(marker => marker is not null)
            .ToList();

        try
        {
            await JS.InvokeVoidAsync("libreRallyMaps.initTileMap",
                -37.814, 144.958, 14, markers);
            mapInit = true;
        }
        catch (JSDisconnectedException)
        {
        }
        catch (TaskCanceledException)
        {
        }
    }

    private async Task Refresh()
        => await Refresh(CancellationToken.None);

    private async Task Refresh(CancellationToken cancellationToken)
    {
        if (disposed)
            return;

        await refreshLock.WaitAsync(cancellationToken);
        try
        {
            tiles = await Api.GetTileCatalogAsync();
            cancellationToken.ThrowIfCancellationRequested();

            lasJobs = (await Api.GetImportJobsAsync())
                .Where(job => job.Type == "las")
                .ToList();
            cancellationToken.ThrowIfCancellationRequested();

            pipelineJobs = await Api.GetPipelineJobsAsync();
            cancellationToken.ThrowIfCancellationRequested();

            imports = await Api.GetImportsAsync();
            cancellationToken.ThrowIfCancellationRequested();

            if (mapInit)
                await DrawMarkers();
        }
        finally
        {
            refreshLock.Release();
        }
    }

    private async Task ProcessNext()
    {
        processing = true; statusMsg = "Starting manual reprocessing for the active import bucket...";

        try
        {
            var response = await Api.StartPipelineAsync();
            statusMsg = response.Message ?? $"Started pipeline job {response.JobId}.";
            await Refresh();
        }
        catch (Exception ex)
        {
            statusMsg = $"Error: {ex.Message}";
        }
        finally { processing = false; }
    }

    private void SelectTile(TileEntry t) => selectedTile = t;

    private async Task PollAsync(CancellationToken cancellationToken)
    {
        using var timer = new PeriodicTimer(TimeSpan.FromSeconds(3));

        try
        {
            while (await timer.WaitForNextTickAsync(cancellationToken))
            {
                await Refresh(cancellationToken);
                if (!disposed)
                    await InvokeAsync(StateHasChanged);
            }
        }
        catch (OperationCanceledException)
        {
        }
    }

    private async Task DisposeMapAsync()
    {
        if (!mapInit)
            return;

        try
        {
            await JS.InvokeVoidAsync("libreRallyMaps.disposeTileMap");
        }
        catch (JSDisconnectedException)
        {
        }
        catch (TaskCanceledException)
        {
        }
    }

    private static bool TryGetTileCenter(TileEntry tile, out double lat, out double lon)
    {
        lat = 0;
        lon = 0;

        if (!tile.TileX.HasValue || !tile.TileY.HasValue || !tile.ZoomLevel.HasValue)
            return false;

        var n = Math.Pow(2, tile.ZoomLevel.Value);
        lon = ((tile.TileX.Value + 0.5) / n * 360.0) - 180.0;
        var latRadians = Math.Atan(Math.Sinh(Math.PI * (1 - (2 * (tile.TileY.Value + 0.5) / n))));
        lat = latRadians * 180.0 / Math.PI;
        return true;
    }

    private ImportJobDisplay? FindRelatedImportJob(TileEntry tile)
    {
        if (tile.SourceImportIds?.Length > 0)
        {
            var matchedByImport = lasJobs.FirstOrDefault(job => job.ImportId.HasValue && tile.SourceImportIds.Contains(job.ImportId.Value));
            if (matchedByImport is not null)
                return matchedByImport;
        }

        return lasJobs.FirstOrDefault(job =>
            job.ZoomLevel == tile.ZoomLevel &&
            job.TileX == tile.TileX &&
            job.TileY == tile.TileY);
    }

    private PipelineJob? FindRelatedPipelineJob(TileEntry tile)
    {
        if (tile.SourceImportIds?.Length > 0)
        {
            var matchedByImport = pipelineJobs.FirstOrDefault(job =>
                job.SourceImportIds is not null &&
                job.SourceImportIds.Any(tile.SourceImportIds.Contains));
            if (matchedByImport is not null)
                return matchedByImport;
        }

        return pipelineJobs.FirstOrDefault(job =>
            job.ZoomLevel == tile.ZoomLevel &&
            job.TileX == tile.TileX &&
            job.TileY == tile.TileY);
    }

    private static string FormatStatus(string status)
        => status switch
        {
            "saving" => "saving",
            "queued" => "queued",
            "starting" => "processing",
            "analyzing" => "analyzing",
            "registering" => "registering",
            "assembling_input" => "assembling input",
            "loading_las" => "loading las",
            "classifying" => "classifying",
            "segmenting" => "segmenting",
            "reconstructing" => "reconstructing",
            "generating_glb" => "generating glb",
            "generated_glb" => "generated glb",
            "registering_tile" => "registering tile",
            "complete" => "complete",
            "rejected" => "rejected",
            "loading" => "loading",
            _ => status
        };

    private static string GetStatusBadgeClass(string status)
        => status switch
        {
            "complete" => "bg-success",
            "error" => "bg-danger",
            "rejected" => "bg-warning text-dark",
            "registering_tile" or "loading" => "bg-warning text-dark",
            "analyzing" or "registering" or "assembling_input" or "starting" or "loading_las" or "classifying" or "segmenting" or "reconstructing" or "generating_glb" or "generated_glb" => "bg-primary",
            _ => "bg-info text-dark"
        };

    private static string GetProgressBarClass(string status)
        => status switch
        {
            "complete" => "bg-success",
            "error" => "bg-danger",
            "rejected" => "bg-warning",
            "registering_tile" => "bg-warning",
            _ => "bg-primary"
        };

    private static bool IsActiveStatus(string status)
        => status is not ("complete" or "error" or "rejected");

    private static int GetProgressPercent(int currentStage, int totalStages, string status)
    {
        if (string.Equals(status, "complete", StringComparison.OrdinalIgnoreCase))
            return 100;

        if (totalStages <= 0)
            return 0;

        var percent = (int)Math.Round(currentStage * 100d / totalStages, MidpointRounding.AwayFromZero);
        return Math.Clamp(percent, 5, 99);
    }

    private static string GetProgressSummary(int currentStage, int totalStages)
        => totalStages > 0
            ? $"Stage {Math.Clamp(currentStage, 1, totalStages)}/{totalStages}"
            : "In progress";

    private static string GetBatchSummary(int? currentBatchIndex, int? totalBatches)
        => currentBatchIndex.HasValue && totalBatches.HasValue && totalBatches.Value > 1
            ? $"Batch {currentBatchIndex.Value} of {totalBatches.Value} in the active bucket rebuild."
            : "Processing active import bucket.";
}
